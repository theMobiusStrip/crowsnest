{
  "name": "crowsnest",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first ingest + detection service for coble fleet logs.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "detect": "tsx src/detect.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ch:up": "docker compose -f docker/docker-compose.yml up -d",
    "ch:down": "docker compose -f docker/docker-compose.yml down"
  },
  "dependencies": {
    "@clickhouse/client": "^1.4.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
